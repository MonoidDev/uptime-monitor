datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id    Int     @id @default(autoincrement())
  name  String
  email String @unique
  isAdmin Boolean @default(false)
  password String
  websites Website[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Website {
  id    Int     @id @default(autoincrement())
  name  String
  url   String
  pingInterval Int
  enabled  Boolean @default(false)
  userId Int
  user User @relation(fields: [userId], references: [id])
  traces Trace[]
  events Event[]
  emails String[]
  errorPredicate ErrorPredicate @default(HTTP_2XX_ONLY)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Trace {
  id    Int     @id @default(autoincrement())
  traceType TraceType
  userId Int
  websiteId Int
  website Website @relation(fields: [websiteId], references: [id])
  status TraceStatus @default(OK)
  httpStatusCode Int?
  duration Int
  requestHeaders String?
  responseHeaders String?
  responseData String?
  event Event?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Event {
  id    Int     @id @default(autoincrement())
  type  String
  websiteId Int
  website Website @relation(fields: [websiteId], references: [id])
  status SeverityType @default(LOG)
  traceId Int?
  trace Trace? @relation(fields: [traceId], references: [id])
  data String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

enum SeverityType {
  LOG
  INFO
  WARN
  ERROR
  FATAL
}

enum TraceType {
  PING
}

enum TraceStatus {
  OK
  TIMEOUT
  HTTP_ERROR
  SSL_ERROR
  DNS_ERROR
  IO_ERROR
  INTERNAL_ERROR
}

enum ErrorPredicate {
  HTTP_2XX_ONLY
  HTTP_NOT_5XX
}
