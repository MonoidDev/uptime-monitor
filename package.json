{
  "name": "uptime-monitor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "npx husky install && npx patch-package",
    "dev": "yarn build:config && npx concurrently npm:dev:watch-*",
    "dev:watch-url": "npx ts-node scripts/emitNextUrls.ts watch",
    "dev:watch-dev": "npx next dev",
    "dev:watch-gql": "npx ts-node-dev --transpile-only --no-notify --respawn scripts/emitGqlSchema.ts",
    "dev:watch-cg": "graphql-codegen --watch --config codegen.yml",
    "build": "yarn gen-type && yarn build:config && yarn build:url && yarn build:gql && yarn build:cg && npx next build",
    "build:url": "npx ts-node scripts/emitNextUrls.ts",
    "build:gql": "npx ts-node --transpile-only scripts/emitGqlSchema.ts",
    "build:config": "npx ts-node config/build.ts",
    "build:cg": "npx graphql-codegen --config codegen.yml",
    "start": "npx next start",
    "lint": "npx eslint . --ext .ts,.tsx",
    "gen-type": "yarn prisma generate",
    "dev:env": "npx dotenv -e .env.development --",
    "dev:db-push": "yarn dev:env prisma db push",
    "prod:env": "npx dotenv -e .env.production --",
    "prod:db-push": "yarn prod:env prisma db push"
  },
  "dependencies": {
    "@ant-design/icons": "^4.6.4",
    "@apollo/client": "^3.4.7",
    "@monoid-dev/use-search": "^0.1.1",
    "@prisma/client": "2.28.0",
    "abort-controller": "^3.0.0",
    "antd": "^4.16.13",
    "apollo-server": "^3.1.2",
    "apollo-server-errors": "^3.1.0",
    "apollo-server-micro": "^3.3.0",
    "apollo-server-plugin-operation-registry": "^3.2.0",
    "autoprefixer": "^10.3.4",
    "classnames": "^2.3.1",
    "dayjs": "^1.10.7",
    "dotenv": "^10.0.0",
    "fp-ts": "^2.11.2",
    "graphql": "^15.5.1",
    "graphql-middleware": "^6.1.1",
    "graphql-shield": "^7.5.0",
    "io-ts": "^2.2.16",
    "jsonwebtoken": "^8.5.1",
    "less": "^4.1.1",
    "less-loader": "^10.0.1",
    "lodash": "^4.17.21",
    "micro": "^9.3.4",
    "next": "11.1.2",
    "next-with-less": "^1.0.1",
    "nexus": "^1.1.0",
    "nexus-plugin-prisma": "^0.35.0",
    "node-fetch": "^3.0.0",
    "node-schedule": "^2.0.0",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-localization": "^1.0.17",
    "recharts": "2.0.9",
    "tailwindcss": "^2.2.15",
    "tyrann-io": "^0.8.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "2.0.1",
    "@graphql-codegen/introspection": "^2.0.0",
    "@graphql-codegen/typescript": "^2.0.0",
    "@graphql-codegen/typescript-operations": "^2.0.1",
    "@graphql-codegen/typescript-react-apollo": "^3.0.0",
    "@types/debounce": "^1.2.0",
    "@types/lodash": "^4.14.173",
    "@types/node": "^16.9.1",
    "@types/prettier": "^2.3.2",
    "@types/react": "^17.0.20",
    "@types/tailwindcss": "^2.2.1",
    "@typescript-eslint/eslint-plugin": "^4.29.3",
    "@typescript-eslint/parser": "^4.29.3",
    "apollo-cli": "^0.4.0",
    "chokidar": "^3.5.2",
    "concurrently": "^6.2.1",
    "cz-conventional-changelog": "^3.3.0",
    "debounce": "^1.2.1",
    "dotenv-cli": "^4.0.0",
    "esbuild": "^0.12.26",
    "eslint": "^7.32.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-config-airbnb-typescript": "^14.0.0",
    "eslint-config-next": "11.1.2",
    "eslint-plugin-import": "^2.24.2",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-react": "^7.25.1",
    "eslint-plugin-react-hooks": "^4.2.0",
    "husky": "^7.0.2",
    "next-transpile-modules": "^8.0.0",
    "patch-package": "^6.4.7",
    "prettier": "^2.4.0",
    "prisma": "2.28.0",
    "stylelint": "^13.13.1",
    "stylelint-config-standard": "^22.0.0",
    "ts-node": "10.1.0",
    "ts-node-dev": "^1.1.8",
    "typescript": "^4.4.3"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=14.17.5"
  },
  "resolutions": {
    "postcss": "8.3.6"
  }
}
