{
  "name": "uptime-monitor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "husky install",
    "dev": "yarn build:config && concurrently npm:dev:watch-*",
    "dev:watch-dev": "next dev",
    "dev:watch-gql": "ts-node-dev --transpile-only --no-notify --respawn scripts/emitGqlSchema.ts",
    "dev:watch-cg": "graphql-codegen --watch --config codegen.yml",
    "build": "yarn build:config && next build",
    "build:config": "esbuild next.config.ts --bundle --outfile=next.config.js --platform=node",
    "build:cg": "graphql-codegen --config codegen.yml",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "gen-type": "yarn prisma generate",
    "dev:env": "dotenv -e .env.development --",
    "dev:db-push": "yarn dev:env prisma db push"
  },
  "dependencies": {
    "@apollo/client": "^3.4.7",
    "@prisma/client": "2.28.0",
    "apollo-server": "^3.1.2",
    "apollo-server-errors": "^3.1.0",
    "apollo-server-micro": "^3.3.0",
    "dotenv": "^10.0.0",
    "fp-ts": "^2.11.2",
    "graphql": "^15.5.1",
    "graphql-middleware": "^6.1.1",
    "graphql-shield": "^7.5.0",
    "io-ts": "^2.2.16",
    "jsonwebtoken": "^8.5.1",
    "micro": "^9.3.4",
    "next": "11.1.2",
    "nexus": "^1.1.0",
    "nexus-plugin-prisma": "^0.35.0",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-localization": "^1.0.17",
    "tyrann-io": "^0.7.8"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "2.0.1",
    "@graphql-codegen/introspection": "^2.0.0",
    "@graphql-codegen/typescript": "^2.0.0",
    "@graphql-codegen/typescript-operations": "^2.0.1",
    "@graphql-codegen/typescript-react-apollo": "^3.0.0",
    "@types/node": "^16.9.1",
    "@types/react": "^17.0.20",
    "@typescript-eslint/eslint-plugin": "^4.29.3",
    "@typescript-eslint/parser": "^4.29.3",
    "apollo-cli": "^0.4.0",
    "concurrently": "^6.2.1",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv-cli": "^4.0.0",
    "esbuild": "^0.12.26",
    "eslint": "^7.32.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-config-airbnb-typescript": "^14.0.0",
    "eslint-config-next": "11.1.2",
    "eslint-plugin-import": "^2.24.2",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-react": "^7.25.1",
    "eslint-plugin-react-hooks": "^4.2.0",
    "husky": "^7.0.2",
    "prisma": "2.28.0",
    "ts-node": "10.1.0",
    "ts-node-dev": "^1.1.8",
    "typescript": "^4.4.3"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=14.17.5"
  }
}
